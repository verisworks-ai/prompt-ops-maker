{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Findings",
  "description": "L2 ANALYZE 레이어 출력. 모든 finding은 evidence_ids 필수.",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence_ids", "confidence"],
        "properties": {
          "claim": {"type": "string"},
          "evidence_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "description": "evidence_ledger의 id 참조. 빈 배열 금지."
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "high=직접증거, medium=간접추론, low=단일정황"
          },
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "HIGH", "MEDIUM", "LOW"]
          }
        }
      }
    }
  }
}
