{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Critique",
  "description": "L4 CRITIQUE 레이어 출력. 7-checks 자기 감사 결과.",
  "type": "object",
  "required": ["violations", "verdict"],
  "properties": {
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "description"],
        "properties": {
          "check_id": {"type": "string"},
          "description": {"type": "string"},
          "severity": {"type": "string", "enum": ["BLOCKER", "HIGH", "MEDIUM", "LOW"]}
        }
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {"type": "string"},
      "description": "추가 수집이 필요한 증거 항목"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "re-collect", "revise"],
      "description": "pass=L5 진행, re-collect=L1 재진입, revise=L2/L3 재실행"
    }
  }
}
