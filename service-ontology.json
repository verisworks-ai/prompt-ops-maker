{
  "routes": [],
  "entities": [
    {
      "name": "ProjectConfig",
      "storage": "configs/*.yaml",
      "fields": [
        "project.name",
        "project.type",
        "project.root",
        "project.domain",
        "core_focus",
        "mode_focus",
        "verification_gates",
        "forbidden",
        "severity"
      ],
      "exposed_at": [
        "fable5_prompt_maker.py make"
      ]
    },
    {
      "name": "TypePreset",
      "storage": "configs/_types/*.yaml",
      "fields": [
        "project.type",
        "core_focus",
        "mode_focus",
        "verification_gates",
        "severity"
      ],
      "exposed_at": [
        "fable5_prompt_maker.py make-adhoc"
      ]
    },
    {
      "name": "PromptArtifact",
      "storage": "outputs/*.md or explicit --output path",
      "fields": [
        "project",
        "mode",
        "task",
        "effort",
        "target_ai",
        "environment",
        "verification_gates",
        "forbidden",
        "report_sections"
      ],
      "exposed_at": [
        "outputs/",
        "stdout --dry-run"
      ]
    }
  ],
  "external_services": [
    {
      "name": "Local Python Runtime",
      "type": "cli-runtime",
      "env": [],
      "used_by": [
        "fable5_prompt_maker.py",
        "tests/test_prompt_maker.py"
      ]
    },
    {
      "name": "PyYAML",
      "type": "python-package",
      "env": [],
      "used_by": [
        "fable5_prompt_maker.py"
      ]
    },
    {
      "name": "Hermes Skill Store",
      "type": "procedural-memory",
      "env": [],
      "used_by": [
        "~/.hermes/skills/software-development/fable5-prompt-maker/SKILL.md"
      ]
    },
    {
      "name": "Research-Vault",
      "type": "obsidian-ontology",
      "env": [],
      "used_by": [
        "wiki/entities/fable5-prompt-maker.md",
        "wiki/sources/fable5-prompt-maker-ops-ontology-2026-07-03.md"
      ]
    }
  ],
  "jobs": [
    {
      "name": "list-projects",
      "schedule": "manual",
      "handler": "python3 fable5_prompt_maker.py list-projects",
      "auth": "required"
    },
    {
      "name": "list-types",
      "schedule": "manual",
      "handler": "python3 fable5_prompt_maker.py list-types",
      "auth": "required"
    },
    {
      "name": "make-project-prompt",
      "schedule": "manual",
      "handler": "python3 fable5_prompt_maker.py make --project <project> --mode <mode> --task <task>",
      "auth": "required"
    },
    {
      "name": "make-adhoc-prompt",
      "schedule": "manual",
      "handler": "python3 fable5_prompt_maker.py make-adhoc --name <name> --type <type> --task <task>",
      "auth": "required"
    },
    {
      "name": "regression-test",
      "schedule": "manual-before-release",
      "handler": "python3 -m pytest -q",
      "auth": "required"
    }
  ],
  "agent_os": {
    "projects": [
      {
        "id": "fable5-prompt-maker",
        "name": "Fable 5 Prompt Maker / Prompt Ops Maker",
        "status": "local-tool-ontology-captured"
      }
    ],
    "agents": [
      {
        "id": "codex-hermes",
        "role": "implementation-ontology-capture-verification"
      },
      {
        "id": "gem-hermes",
        "role": "research-strategy-copy-review"
      }
    ],
    "surfaces": [
      {
        "id": "surface-cli",
        "type": "cli",
        "project_context_id": "fable5-prompt-maker",
        "artifacts": [
          "fable5_prompt_maker.py",
          "configs/*.yaml",
          "configs/_types/*.yaml"
        ]
      },
      {
        "id": "surface-tests",
        "type": "quality-gate",
        "project_context_id": "fable5-prompt-maker",
        "artifacts": [
          "tests/test_prompt_maker.py",
          "pytest output"
        ]
      },
      {
        "id": "surface-skill",
        "type": "procedural-memory",
        "project_context_id": "fable5-prompt-maker",
        "artifacts": [
          "~/.hermes/skills/software-development/fable5-prompt-maker/SKILL.md"
        ]
      },
      {
        "id": "surface-obsidian",
        "type": "obsidian-ontology",
        "project_context_id": "fable5-prompt-maker",
        "artifacts": [
          "Research-Vault/wiki/entities/fable5-prompt-maker.md",
          "Research-Vault/wiki/sources/fable5-prompt-maker-ops-ontology-2026-07-03.md",
          "Research-Vault/wiki/concepts/model-agnostic-prompt-operations.md"
        ]
      }
    ],
    "tasks": [
